{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and usage stats",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "toolUsage": { "type": "object" }
      },
      "required": ["name", "email", "createdAt"]
    },
    "ExplainerEntry": {
      "title": "Explainer Entry",
      "description": "History of 5-minute explanations",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "topic": { "type": "string" },
        "minutes": { "type": "number" },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "WriteUnblockEntry": {
      "title": "Write Unblock Entry",
      "description": "History of assignment unblocking",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "question": { "type": "string" },
        "thoughts": { "type": "string" },
        "result": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ErrorLogEntry": {
      "title": "Error Log Entry",
      "description": "History of mistakes and diagnoses",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "question": { "type": "string" },
        "userAnswer": { "type": "string" },
        "correctAnswer": { "type": "string" },
        "diagnosis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "StudyPlan": {
      "title": "Study Plan",
      "description": "Personalized study schedules",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "examName": { "type": "string" },
        "examDate": { "type": "string" },
        "topics": { "type": "array" },
        "hoursPerDay": { "type": "number" },
        "plan": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "PYQResult": {
      "title": "PYQ Result",
      "description": "Analysis of past year papers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "fileName": { "type": "string" },
        "subject": { "type": "string" },
        "questionsCount": { "type": "number" },
        "results": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "LectureNote": {
      "title": "Lecture Note",
      "description": "Digest of recorded or uploaded lectures",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "rawTranscript": { "type": "string" },
        "structuredNotes": { "type": "string" },
        "examPoints": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "TeachSession": {
      "title": "Teach Session",
      "description": "History of Socratic teaching sessions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "topic": { "type": "string" },
        "messages": { "type": "array" },
        "masteryScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ConceptMap": {
      "title": "Concept Map",
      "description": "Visual knowledge graphs",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "topics": { "type": "array" },
        "graph": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CollaborativeSession": {
      "title": "Collaborative Session",
      "description": "Real-time shared study workspace",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["study-plan", "mind-map"] },
        "content": { "type": "object" },
        "createdBy": { "type": "string" },
        "members": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "type", "content", "createdBy", "members", "createdAt", "updatedAt"]
    },
    "PresenceInfo": {
      "title": "Presence Info",
      "description": "User presence in a session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "lastSeen"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "explainerHistory/{entryId}": {
      "schema": "ExplainerEntry",
      "description": "Explainer logs"
    },
    "writeUnblockHistory/{entryId}": {
      "schema": "WriteUnblockEntry",
      "description": "Write unblock logs"
    },
    "errorLog/{entryId}": {
      "schema": "ErrorLogEntry",
      "description": "Error diagnostic logs"
    },
    "studyPlans/{userId}": {
      "schema": "StudyPlan",
      "description": "Study plans for a user"
    },
    "pyqResults/{entryId}": {
      "schema": "PYQResult",
      "description": "PYQ analysis results"
    },
    "lectureNotes/{entryId}": {
      "schema": "LectureNote",
      "description": "Lecture notes logs"
    },
    "teachSessions/{entryId}": {
      "schema": "TeachSession",
      "description": "Teach session logs"
    },
    "conceptMaps/{entryId}": {
      "schema": "ConceptMap",
      "description": "Concept maps logs"
    },
    "collabSessions/{sessionId}": {
      "schema": "CollaborativeSession",
      "description": "Collaborative workspaces"
    },
    "collabSessions/{sessionId}/presence/{userId}": {
      "schema": "PresenceInfo",
      "description": "User presence in collab workspace"
    }
  }
}
